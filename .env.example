# ============================================================
#  .env.example  →  コピーして .env にリネームして使う
# ============================================================

# JWT署名シークレット（必ず長いランダム文字列に変更すること）
# 生成例: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-this

# サーバーポート
PORT=8000

# 環境 (development / production)
# production にすると Cookie の secure フラグが ON になる（HTTPS必須）
NODE_ENV=development

# 漫画データディレクトリ（絶対パスまたは相対パス）
MANGA_DIR=./manga_data
